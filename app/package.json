{
    "name": "zenkash",
    "version": "0.0.4",
    "description": "Personal finance management app",
    "productName": "Zenkash",
    "author": "Didier Tagne <tagnedidier@gmail.com>",
    "type": "module",
    "private": true,
    "scripts": {
        "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\" && vue-tsc --noEmit",
        "lint:eslint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
        "lintfix": "prettier --write \"src/**/*.{js,ts,vue,css,scss,html,md,json}\" \"scripts/**/*.js\" \"*.json\" \"*.html\"",
        "typecheck": "vue-tsc --noEmit",
        "test": "echo \"No test specified\" && exit 0",
        "dev": "quasar dev",
        "build": "quasar build",
        "android": "node scripts/build-android.js",
        "ios": "quasar build -m capacitor -T ios --ide",
        "postinstall": "quasar prepare",
        "prepare": "husky",
        "assets:source": "node scripts/generate-assets.js",
        "assets:icons": "node scripts/generate-assets.js && mkdir -p src-capacitor/assets && cp assets/*.png src-capacitor/assets/ && cd src-capacitor && npx capacitor-assets generate --android && rm -rf assets",
        "assets": "yarn assets:icons"
    },
    "dependencies": {
        "@capacitor-community/sqlite": "^8.1.0",
        "@capacitor/app": "^8.1.0",
        "@capacitor/core": "^8.3.1",
        "@capacitor/local-notifications": "^8.0.2",
        "@quasar/extras": "^1.16.4",
        "capacitor-plugin-safe-area": "^5.0.0",
        "chart.js": "^4.5.1",
        "pinia": "^3.0.1",
        "quasar": "^2.16.0",
        "sql.js": "1.11.0",
        "uuid": "^14.0.0",
        "vue": "^3.5.22",
        "vue-chartjs": "^5.3.3",
        "vue-i18n": "^11.3.0",
        "vue-router": "^5.0.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@eslint/js": "^9.39.4",
        "@intlify/unplugin-vue-i18n": "^11.0.0",
        "@quasar/app-vite": "^2.5.1",
        "@types/node": "^22.19.11",
        "@types/uuid": "^11.0.0",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "autoprefixer": "^10.4.27",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.1",
        "prettier": "^3.8.1",
        "sharp": "^0.33.5",
        "typescript": "^6.0.3",
        "unplugin-auto-import": "^21.0.0",
        "vite-plugin-checker": "^0.12.0",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.7"
    },
    "engines": {
        "node": "^28 || ^26 || ^24 || ^22.12",
        "yarn": ">= 1.21.1"
    },
    "lint-staged": {
        "*.{ts,js,vue}": [
            "eslint -c ./eslint.config.js --fix"
        ]
    },
    "prettier": {
        "semi": true,
        "singleQuote": true,
        "trailingComma": "all",
        "printWidth": 100,
        "tabWidth": 4
    }
}
